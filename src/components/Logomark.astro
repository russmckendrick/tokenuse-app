---
interface Props {
  size?: number;
  color?: string;
}

const { size = 28, color = "currentColor" } = Astro.props;
---

<svg width={size} height={size * 0.85} viewBox="0 0 40 34" fill="none" aria-hidden="true">
  <rect x="0" y="20" width="6" height="14" fill={color}></rect>
  <rect x="9" y="12" width="6" height="22" fill={color}></rect>
  <rect x="18" y="6" width="6" height="28" fill={color}></rect>
  <rect x="27" y="0" width="6" height="34" fill={color}></rect>
</svg>
