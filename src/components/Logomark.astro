---
import { LOGOMARK_BARS, LOGOMARK_GRADIENT_STOPS, LOGOMARK_VIEWBOX } from "../lib/logomark.mjs";

interface Props {
  size?: number;
  color?: string;
  gradient?: boolean;
  gradientId?: string;
}

const {
  size = 32,
  color = "currentColor",
  gradient = false,
  gradientId = "token-use-bars-gradient",
} = Astro.props;
const width = size * (LOGOMARK_VIEWBOX.width / LOGOMARK_VIEWBOX.height);
const fill = gradient ? `url(#${gradientId})` : color;
---

<svg width={width} height={size} viewBox={`0 0 ${LOGOMARK_VIEWBOX.width} ${LOGOMARK_VIEWBOX.height}`} fill="none" aria-hidden="true">
  {gradient && (
    <defs>
      <linearGradient id={gradientId} x1="0" y1="0" x2="0" y2={LOGOMARK_VIEWBOX.height} gradientUnits="userSpaceOnUse">
        {LOGOMARK_GRADIENT_STOPS.map((stop) => (
          <stop offset={`${stop.offset * 100}%`} stop-color={stop.color}></stop>
        ))}
      </linearGradient>
    </defs>
  )}
  {LOGOMARK_BARS.map((bar) => (
    <rect x={bar.x} y={bar.y} width={bar.width} height={bar.height} rx={bar.rx} fill={fill}></rect>
  ))}
</svg>
