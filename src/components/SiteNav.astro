---
import GitHubIcon from "./GitHubIcon.astro";
import Logomark from "./Logomark.astro";

const githubUrl = "https://github.com/russmckendrick/tokenuse";
---

<nav class="nav">
  <div class="nav-inner">
    <a class="brand" href="/">
      <Logomark gradient gradientId="site-nav-bars-gradient" />
      <span class="brand-word">Token Use</span>
    </a>
    <div class="nav-links" aria-label="Primary navigation">
      <a href="/docs/">Docs</a>
      <a href="/releases/">Releases</a>
      <a href={githubUrl} class="nav-cta">
        <GitHubIcon />
        <span>GitHub</span>
      </a>
    </div>
    <details class="nav-menu">
      <summary aria-label="Open primary navigation">
        <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8"></path>
        </svg>
      </summary>
      <div class="nav-menu-panel" aria-label="Primary navigation">
        <a href="/docs/">Docs</a>
        <a href="/releases/">Releases</a>
        <a href={githubUrl}>
          <GitHubIcon />
          <span>GitHub</span>
        </a>
      </div>
    </details>
  </div>
</nav>
