---
import type { NavIconDef } from "../config/nav";

interface Props {
  icon: NavIconDef;
  size?: number;
}

const { icon, size = 14 } = Astro.props;
const isStroke = icon.stroke !== false;
const viewBox = icon.viewBox ?? (isStroke ? "0 0 24 24" : "0 0 16 16");
---

{isStroke ? (
  <svg viewBox={viewBox} width={size} height={size} fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" set:html={icon.paths} />
) : (
  <svg viewBox={viewBox} width={size} height={size} fill="currentColor" aria-hidden="true" set:html={icon.paths} />
)}
