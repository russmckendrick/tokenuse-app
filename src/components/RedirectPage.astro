---
import { absoluteSiteUrl } from "../lib/seo";

interface Props {
  title: string;
  to: string;
}

const { title, to } = Astro.props;
const destinationUrl = absoluteSiteUrl(to);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex,follow" />
    <meta http-equiv="refresh" content={`0; url=${destinationUrl}`} />
    <link rel="canonical" href={destinationUrl} />
    <title>{title}</title>
  </head>
  <body>
    <p><a href={destinationUrl}>Continue to {to}</a></p>
  </body>
</html>
