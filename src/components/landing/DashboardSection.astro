---
import TerminalPreview from "./TerminalPreview.astro";
---

<section id="dashboard" class="section section-terminal">
  <div class="section-head">
    <div class="section-eyebrow">THE DASHBOARD</div>
    <h2 class="section-h2">
      A dense terminal that answers the only question that matters:
      <span class="ink">where did it go?</span>
    </h2>
    <p class="section-lede">
      Every panel is keyboard-driven. Press <kbd>1</kbd>-<kbd>5</kbd> to change the time range,
      <kbd>t</kbd> to cycle tools, <kbd>p</kbd> to pick a project, <kbd>e</kbd> to export. Press
      <kbd>?</kbd> at any time for the full keymap.
    </p>
  </div>
  <TerminalPreview />
</section>
