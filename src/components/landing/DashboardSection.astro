---
import TerminalPreview from "./TerminalPreview.astro";
---

<section id="dashboard" class="section section-terminal">
  <div class="section-head">
    <div class="section-eyebrow">THE DASHBOARD</div>
    <h2 class="section-h2">
      A local dashboard that answers the only question that matters:
      <span class="ink">where did it go?</span>
    </h2>
    <p class="section-lede">
      The TUI and desktop app share the same archive, filters, refresh logic, and export path. In the terminal,
      press <kbd>1</kbd>-<kbd>5</kbd> for time ranges, <kbd>t</kbd> for tools, <kbd>p</kbd> for projects, and
      <kbd>e</kbd> to export.
    </p>
  </div>
  <TerminalPreview />
</section>
