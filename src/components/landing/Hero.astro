---
import wideHero from "../../assets/hero-wide.png";
import tallHero from "../../assets/hero-tall.png";

interface Props {
  latestVersion: string;
  releaseHref: string;
}

const { latestVersion, releaseHref } = Astro.props;
---

<header id="top" class="hero">
  <div class="hero-image-wrap">
    <video class="hero-image hero-video hero-video-wide" autoplay muted loop playsinline poster={wideHero.src}>
      <source src="/vids/hero-wide.mp4" type="video/mp4" />
    </video>
    <video class="hero-image hero-video hero-video-tall" autoplay muted loop playsinline poster={tallHero.src}>
      <source src="/vids/hero-tall.mp4" type="video/mp4" />
    </video>
    <picture class="hero-image-static">
      <source media="(max-width: 760px)" srcset={tallHero.src} width={tallHero.width} height={tallHero.height} />
      <img
        class="hero-image"
        src={wideHero.src}
        width={wideHero.width}
        height={wideHero.height}
        alt="A broadcast studio set for token use, with operators and panels for AI coding tools."
        fetchpriority="high"
        decoding="async"
      />
    </picture>
    <div class="hero-vignette"></div>
    <div class="scanlines" aria-hidden="true"></div>
  </div>

  <div class="hero-foot">
    <div class="hero-foot-row">
      <div class="hero-foot-left">
        <div class="hero-eyebrow">{latestVersion} - TUI + desktop app</div>
        <h1 class="hero-h1">Track AI coding <span class="ink">token usage</span> and costs locally.</h1>
        <p class="hero-sub">
          Token Use reads Claude Code, Codex, Cursor, GitHub Copilot, and Gemini history already on your
          machine, stores it in a local archive, and adds local Insights plus optional quota gauges when you
          choose to sync them.
        </p>
        <div class="hero-cta">
          <a class="btn btn-primary" href="/docs/guides/installation/"><span class="btn-key">&gt;</span> Install Token Use</a>
          <a class="btn btn-ghost" href={releaseHref}>Latest release <span aria-hidden="true">-&gt;</span></a>
        </div>
        <div class="hero-meta">
          <span>No API keys</span>
          <span>Read-only ingestion</span>
          <span>No telemetry</span>
          <span>Opt-in syncs only</span>
        </div>
      </div>

      <div class="hero-foot-right">
        <div class="callcard">
          <div class="callcard-strip"></div>
          <div class="callcard-label">CURRENT RELEASE</div>
          <div class="callcard-num">{latestVersion}</div>
          <div class="callcard-sub">Homebrew, TUI binaries, and desktop builds</div>
        </div>
      </div>
    </div>
  </div>
</header>
