---
import "../styles/global.css";
import { LOGOMARK_COLORS } from "../lib/logomark.mjs";

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
}

const {
  title = "token use - local-first token and cost usage explorer",
  description = "Token Use is a local-first TUI and macOS desktop app for exploring AI coding tool token and cost usage across Claude Code, Codex, Cursor, and GitHub Copilot.",
  bodyClass = ""
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content={LOGOMARK_COLORS.background} />
    <meta name="msapplication-TileColor" content={LOGOMARK_COLORS.background} />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color={LOGOMARK_COLORS.brass} />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=Inter+Tight:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600;700&family=Caveat:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class={bodyClass} data-palette="broadcast" data-grain="true">
    <slot />
  </body>
</html>
