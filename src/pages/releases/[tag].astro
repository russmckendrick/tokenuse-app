---
import DocsLayout from "../../layouts/DocsLayout.astro";
import ReleaseArticle from "../../components/ReleaseArticle.astro";
import ReleasePager from "../../components/ReleasePager.astro";
import { getReleases, type Release } from "../../lib/releases";
import { SITE_NAME, absoluteSiteUrl } from "../../lib/seo";

export async function getStaticPaths() {
  const releases = await getReleases();
  const latestStableTag = releases.find((release) => !release.prerelease)?.tag;

  return releases.map((release, index) => ({
    params: { tag: release.tag },
    props: {
      release,
      isLatestStable: release.tag === latestStableTag,
      older: releases[index + 1] ?? null,
      newer: releases[index - 1] ?? null,
    },
  }));
}

interface Props {
  release: Release;
  isLatestStable: boolean;
  older: Release | null;
  newer: Release | null;
}

const { release, isLatestStable, older, newer } = Astro.props;
const releaseUrl = absoluteSiteUrl(`/releases/${release.tag}/`);
const releaseTitle = `${release.tag} Release - Token Use Release Notes`;
const releaseJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: releaseTitle,
  description: release.name,
  url: releaseUrl,
  mainEntityOfPage: releaseUrl,
  datePublished: release.publishedAt || undefined,
  dateModified: release.publishedAt || undefined,
  isPartOf: {
    "@type": "WebSite",
    name: SITE_NAME,
    url: absoluteSiteUrl("/"),
  },
  publisher: {
    "@type": "Organization",
    name: SITE_NAME,
    url: absoluteSiteUrl("/"),
  },
};
---

<DocsLayout title={`${release.tag} Release`} seoTitle={releaseTitle} description={release.name} ogType="article" jsonLd={releaseJsonLd}>
  <a class="release-breadcrumb" href="/releases/">All releases</a>
  <ReleaseArticle release={release} isLatestStable={isLatestStable} />
  <ReleasePager newer={newer} older={older} />
</DocsLayout>
