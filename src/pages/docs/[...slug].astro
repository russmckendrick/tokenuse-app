---
import DocsPage from "../../components/DocsPage.astro";
import { docsPages, getDocsEntry, getDocsPageBySlug, getToolDocsPages, slugForDocsPage, type DocsPageMeta } from "../../lib/docs";

export async function getStaticPaths() {
  const toolPages = await getToolDocsPages();
  return [...docsPages, ...toolPages]
    .filter((page) => page.href !== "/docs/")
    .map((page) => ({
      params: { slug: slugForDocsPage(page) },
      props: { page },
    }));
}

interface Props {
  page: DocsPageMeta;
}

const page = Astro.props.page ?? getDocsPageBySlug(Astro.params.slug);
if (!page) throw new Error(`Unknown docs route: ${Astro.params.slug ?? ""}`);

const entry = await getDocsEntry(page);
---

<DocsPage entry={entry} page={page} />
