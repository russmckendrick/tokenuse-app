---
import { getCollection } from "astro:content";
import RedirectPage from "../../../components/RedirectPage.astro";

export async function getStaticPaths() {
  const entries = await getCollection("tokenuseDocs");
  const slugs = entries
    .filter((e) => e.id.startsWith("development/tools/") && e.id !== "development/tools/readme")
    .map((e) => e.id.replace("development/tools/", ""));
  return slugs.map((slug) => ({ params: { slug } }));
}

const to = `/docs/development/tools/${Astro.params.slug}/`;
---

<RedirectPage title="Tool docs moved" to={to} />
