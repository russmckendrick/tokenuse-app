{
	"compatibility_date": "2026-04-30",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "tokenuse-app",
	"main": "src/worker.ts",
	"assets": {
		"directory": "./dist/client",
		"binding": "ASSETS",
		"run_worker_first": true
	},
	"routes": [
		{ "pattern": "tokenuse.app", "custom_domain": true },
		{ "pattern": "www.tokenuse.app", "custom_domain": true }
	],
	"observability": {
		"enabled": true
	}
}
